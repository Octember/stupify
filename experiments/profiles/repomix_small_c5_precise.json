{
  "id": "repomix_small_c5_precise",
  "context": "repomix",
  "maxCandidates": 5,
  "maxSearchInputTokens": 12000,
  "includeCounterReasonInPrompt": true,
  "repomix": {
    "compress": true,
    "showLineNumbers": true,
    "removeEmptyLines": true,
    "maxFileBytes": 49152,
    "maxTotalBytes": 131072
  },
  "patterns": {
    "unnecessary_complexity": { "enabled": true },
    "over_commenting": { "enabled": true },
    "lint_bypass": { "enabled": true },
    "duplicated_schema": { "enabled": true },
    "reinvented_utils": { "enabled": true }
  }
}
