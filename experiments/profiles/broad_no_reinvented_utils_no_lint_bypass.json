{
  "id": "broad_no_reinvented_utils_no_lint_bypass",
  "context": "repomix",
  "maxCandidates": 5,
  "maxSearchInputTokens": 12000,
  "includeCounterReasonInPrompt": false,
  "repomix": {
    "compress": true,
    "showLineNumbers": true,
    "removeEmptyLines": true,
    "maxFileBytes": 24576,
    "maxTotalBytes": 65536
  },
  "patterns": {
    "unnecessary_complexity": { "enabled": true },
    "over_commenting": { "enabled": true },
    "duplicated_schema": { "enabled": true }
  }
}
