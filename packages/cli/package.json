{
  "name": "@stupify/cli",
  "version": "0.0.17",
  "description": "Local-only diagnostic CLI for checking whether AI is making you dumber.",
  "private": false,
  "type": "module",
  "bin": {
    "stupify": "dist/stupify.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Octember/stupif.ai.git",
    "directory": "packages/cli"
  },
  "homepage": "https://stupif.ai",
  "bugs": {
    "url": "https://github.com/Octember/stupif.ai/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "local-first",
    "code-review"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json",
    "smoke": "bun run build && node ./dist/stupify.js --help"
  },
  "dependencies": {
    "@ataraxy-labs/sem": "^0.3.24",
    "@clack/prompts": "^1.2.0",
    "picocolors": "^1.1.1",
    "repomix": "^1.14.0"
  }
}
