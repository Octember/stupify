{
  "extends": "./tsconfig.base.json",
  "include": [
    "app/**/*",
    "workers/**/*",
    "vite.config.ts",
    "react-router.config.ts",
    "worker-configuration.d.ts",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "noEmit": true
  }
}
