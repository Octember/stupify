{
  "name": "@stupify/cli",
  "version": "0.4.5",
  "description": "A code reviewer that talks like an idiot and catches real bugs — corpus-grounded, anti-slop, runs on Codex.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "stupify": "bin/stupify.js"
  },
  "files": [
    "bin/stupify.js",
    "src/cli.ts",
    "src/prime.ts",
    "src/review-sweep.ts",
    ".review",
    "packs",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "homepage": "https://stupif.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Octember/stupify.git"
  },
  "bugs": {
    "url": "https://github.com/Octember/stupify/issues"
  },
  "keywords": [
    "code-review",
    "codex",
    "ai",
    "pull-request",
    "developer-tools",
    "anti-slop"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "bun test",
    "cli": "bun src/cli.ts"
  },
  "dependencies": {
    "@stupify/exe-cli": "0.4.5",
    "@stupify/exe-host": "0.4.5",
    "@clack/prompts": "^1.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
