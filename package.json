{
  "name": "@stupify/cli",
  "version": "0.2.0",
  "description": "A code reviewer that talks like an idiot and catches real bugs — corpus-grounded, anti-slop, runs on Codex.",
  "type": "module",
  "bin": {
    "stupify": "src/cli.ts"
  },
  "files": [
    "src",
    ".review",
    "packs",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "homepage": "https://stupif.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Octember/stupif.ai.git"
  },
  "bugs": {
    "url": "https://github.com/Octember/stupif.ai/issues"
  },
  "keywords": [
    "code-review",
    "codex",
    "ai",
    "pull-request",
    "developer-tools",
    "anti-slop"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "cli": "bun src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
