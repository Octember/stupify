{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stupif-ai",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "workers_dev": false,
  "routes": [
    { "pattern": "stupif.ai/*", "zone_name": "stupif.ai" },
    { "pattern": "www.stupif.ai/*", "zone_name": "stupif.ai" }
  ],
  "observability": {
    "enabled": true
  }
}
